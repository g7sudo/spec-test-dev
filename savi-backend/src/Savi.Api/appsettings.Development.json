{
  "ConnectionStrings": {
    "PlatformDb": "Data Source=savi_platform.db"
  },
  "DatabaseProvider": "sqlite",
  "Firebase": {
    "ProjectId": "dk-dev-app",
    "ServiceAccountJsonPath": "dk-dev-app-firebase-admin.json"
  },
  "RootAdmins": {
    "Emails": [
      "admin@savi.app"
    ]
  },
  "TenantInvitations": {
    "ExpiryDays": 7,
    "DefaultRoleCode": "COMMUNITY_ADMIN",
    "InvitationBaseUrl": "http://localhost:5173/invitations/accept?token={token}",
    "LogInvitationLink": true,
    "ExposeInvitationDetails": true
  },
  "ResidentInvitations": {
    "DefaultExpiryDays": 7,
    "InvitationBaseUrl": "http://localhost:3000/tenant/{tenantSlug}/accept-invite?inviteId={inviteId}&token={token}",
    "LogInvitationLink": true,
    "ExposeInvitationDetails": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Error"
      }
    }
  }
}
